# Core
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<db>
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development

