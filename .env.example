# ===========================================
# Ganapathi Mentor AI - Environment Variables
# Copy to .env.local and fill in values
# ===========================================

# --- Required for auth & database ---
MONGODB_URI=mongodb://localhost:27017/ganapathi
# JWT_SECRET=your-secret-key  # If using custom JWT

# --- Image Generation (Creative Studio) ---
# At least one required for /dashboard/media/studio
STABILITY_API_KEY=        # Stability AI - https://platform.stability.ai
# AIMLAPI_API_KEY=       # AIMLAPI Stable Diffusion - https://aimlapi.com

# --- LLM / AI (Code Review, Docs, Productivity, Learning) ---
# At least one recommended - enables AI features
OPENAI_API_KEY=          # OpenAI - https://platform.openai.com
# GEMINI_API_KEY=       # Google Gemini - https://ai.google.dev
# GROQ_API_KEY=        # Groq - https://console.groq.com (free tier)
# MISTRAL_API_KEY=     # Mistral - https://mistral.ai
# KIMI_API_KEY=       # Moonshot/Kimi - https://platform.moonshot.cn

# --- GitHub Integration ---
GITHUB_TOKEN=            # Personal Access Token - https://github.com/settings/tokens
                         # Scopes: repo, read:user

# --- Optional: Research, Search, Voice ---
# SEMANTIC_SCHOLAR_API_KEY=
# TAVILY_API_KEY=
# ELEVENLABS_API_KEY=
# STACK_APPS_KEY=
