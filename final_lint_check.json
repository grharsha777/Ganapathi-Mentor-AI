I_KEY,\r\n        num: num.toString(),\r\n    });\r\n\r\n    const response = await fetch(`${SERP_BASE_URL}?${params}`);\r\n\r\n    if (!response.ok) {\r\n        throw new Error(`SERP API Error: ${response.statusText}`);\r\n    }\r\n\r\n    const data = await response.json();\r\n    const organicResults = data.organic_results || [];\r\n\r\n    return organicResults.map((r: any) => ({\r\n        title: r.title,\r\n        link: r.link,\r\n        snippet: r.snippet,\r\n        position: r.position,\r\n    }));\r\n}\r\n\r\n/**\r\n * Search for programming-related content\r\n */\r\nexport async function searchProgrammingDocs(query: string): Promise<SearchResult[]> {\r\n    return searchWeb(`${query} programming documentation tutorial`, 5);\r\n}\r\n\r\nexport function isSerpConfigured(): boolean {\r\n    return !!SERP_API_KEY;\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\G R  HARSHA\\OneDrive\\Desktop\\Ganapathi Mentor AI\\neural-code-symbiosis\\lib\\suno.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\G R  HARSHA\\OneDrive\\Desktop\\Ganapathi Mentor AI\\neural-code-symbiosis\\lib\\utils.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\G R  HARSHA\\OneDrive\\Desktop\\Ganapathi Mentor AI\\neural-code-symbiosis\\lib\\video-generation.ts","messages":[{"ruleId":"no-console","severity":1,"message":"Unexpected console statement.","line":63,"column":5,"nodeType":"MemberExpression","messageId":"unexpected","endLine":63,"endColumn":18,"suggestions":[{"fix":{"range":[1767,1828],"text":""},"messageId":"removeConsole","data":{"propertyName":"error"},"desc":"Remove the console.error()."}]},{"ruleId":"no-console","severity":1,"message":"Unexpected console statement.","line":117,"column":5,"nodeType":"MemberExpression","messageId":"unexpected","endLine":117,"endColumn":18,"suggestions":[{"fix":{"range":[3276,3332],"text":""},"messageId":"removeConsole","data":{"propertyName":"error"},"desc":"Remove the console.error()."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'options' is defined but never used.","line":128,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":128,"endColumn":10},{"ruleId":"no-console","severity":1,"message":"Unexpected console statement.","line":148,"column":7,"nodeType":"MemberExpression","messageId":"unexpected","endLine":148,"endColumn":19,"suggestions":[{"fix":{"range":[4401,4468],"text":""},"messageId":"removeConsole","data":{"propertyName":"warn"},"desc":"Remove the console.warn()."}]},{"ruleId":"no-console","severity":1,"message":"Unexpected console statement.","line":170,"column":3,"nodeType":"MemberExpression","messageId":"unexpected","endLine":170,"endColumn":14,"suggestions":[{"fix":{"range":[5024,5069],"text":""},"messageId":"removeConsole","data":{"propertyName":"log"},"desc":"Remove the console.log()."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":5,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/**\r\n * Video Generation Module - Free/Open-Source Alternatives\r\n * Supports: HuggingFace (free), RunwayML (free credits), AWS MediaConvert\r\n * Replaces paid HeyGen subscription\r\n */\r\n\r\nimport { HfInference } from \"@huggingface/inference\";\r\n\r\nconst HF_API_KEY = process.env.HUGGINGFACE_API_KEY;\r\nconst RUNWAY_API_KEY = process.env.RUNWAY_API_KEY;\r\n\r\nexport interface VideoGenerationOptions {\r\n  text: string;\r\n  style?: \"shortform\" | \"tutorial\" | \"presentation\";\r\n  width?: number;\r\n  height?: number;\r\n  durationSeconds?: number;\r\n}\r\n\r\nexport interface VideoGenerationResult {\r\n  videoUrl: string;\r\n  videoId: string;\r\n  provider: \"huggingface\" | \"runway\" | \"aws\";\r\n  status: \"completed\" | \"processing\";\r\n  duration?: number;\r\n}\r\n\r\n// ============================================================\r\n// Option 1: HuggingFace ZeroScope (Completely Free)\r\n// ============================================================\r\nexport async function generateVideoHuggingFace(\r\n  options: VideoGenerationOptions\r\n): Promise<VideoGenerationResult> {\r\n  if (!HF_API_KEY) {\r\n    throw new Error(\r\n      \"HUGGINGFACE_API_KEY is not configured. Get free API key at huggingface.co\"\r\n    );\r\n  }\r\n\r\n  const hf = new HfInference(HF_API_KEY);\r\n\r\n  try {\r\n    // ZeroScope: Free text-to-video model\r\n    const videoBlob = await hf.textToVideo({\r\n      model: \"damo-vilab/text-to-video-ms-1.7b\",\r\n      inputs: options.text,\r\n    }) as Blob;\r\n\r\n    // Upload to S3\r\n    const videoUrl = await uploadVideoToS3(\r\n      videoBlob,\r\n      `generated-videos/${Date.now()}.mp4`\r\n    );\r\n\r\n    return {\r\n      videoUrl,\r\n      videoId: `hf-${Date.now()}`,\r\n      provider: \"huggingface\",\r\n      status: \"completed\",\r\n      duration: options.durationSeconds || 8,\r\n    };\r\n  } catch (error) {\r\n    console.error(\"HuggingFace video generation failed:\", error);\r\n    throw new Error(\r\n      `Failed to generate video with HuggingFace: ${\r\n        (error as Error).message\r\n      }`\r\n    );\r\n  }\r\n}\r\n\r\n// ============================================================\r\n// Option 2: RunwayML (Free Monthly Credits)\r\n// ============================================================\r\nexport async function generateVideoRunway(\r\n  options: VideoGenerationOptions\r\n): Promise<VideoGenerationResult> {\r\n  if (!RUNWAY_API_KEY) {\r\n    throw new Error(\r\n      \"RUNWAY_API_KEY is not configured. Get free credits at runway.com\"\r\n    );\r\n  }\r\n\r\n  try {\r\n    const response = await fetch(\"https://api.runwayml.com/v1/generate\", {\r\n      method: \"POST\",\r\n      headers: {\r\n        Authorization: `Bearer ${RUNWAY_API_KEY}`,\r\n        \"Content-Type\": \"application/json\",\r\n      },\r\n      body: JSON.stringify({\r\n        model: \"gen3a_turbo\",\r\n        prompt: options.text,\r\n        guidance_scale: 7.5,\r\n        num_inference_steps: 20,\r\n        mode: \"text2video\",\r\n      }),\r\n    });\r\n\r\n    if (!response.ok) {\r\n      throw new Error(`Runway API error: ${response.statusText}`);\r\n    }\r\n\r\n    const data = (await response.json()) as {\r\n      id: string;\r\n      output: string[];\r\n      status: string;\r\n    };\r\n\r\n    return {\r\n      videoUrl: data.output?.[0] || \"\",\r\n      videoId: data.id,\r\n      provider: \"runway\",\r\n      status: data.status === \"succeeded\" ? \"completed\" : \"processing\",\r\n    };\r\n  } catch (error) {\r\n    console.error(\"Runway video generation failed:\", error);\r\n    throw new Error(\r\n      `Failed to generate video with Runway: ${(error as Error).message}`\r\n    );\r\n  }\r\n}\r\n\r\n// ============================================================\r\n// Option 3: AWS MediaConvert (Production - Paid)\r\n// ============================================================\r\nexport async function generateVideoAWS(\r\n  options: VideoGenerationOptions\r\n): Promise<VideoGenerationResult> {\r\n  // This would use AWS SDK v3\r\n  // For now, placeholder for future production use\r\n  throw new Error(\r\n    \"AWS MediaConvert requires source video. Use HuggingFace for text-to-video.\"\r\n  );\r\n}\r\n\r\n// ============================================================\r\n// Smart Router: Auto-select best provider\r\n// ============================================================\r\nexport async function generateVideo(\r\n  options: VideoGenerationOptions\r\n): Promise<VideoGenerationResult> {\r\n  // Priority: Runway (quality) > HuggingFace (free & fast)\r\n  if (RUNWAY_API_KEY) {\r\n    try {\r\n      return await generateVideoRunway(options);\r\n    } catch (error) {\r\n      console.warn(\"Runway failed, falling back to HuggingFace:\", error);\r\n    }\r\n  }\r\n\r\n  if (HF_API_KEY) {\r\n    return await generateVideoHuggingFace(options);\r\n  }\r\n\r\n  throw new Error(\r\n    \"No video generation provider configured. Set HUGGINGFACE_API_KEY or RUNWAY_API_KEY\"\r\n  );\r\n}\r\n\r\n// ============================================================\r\n// Helper: Upload video to S3\r\n// ============================================================\r\nasync function uploadVideoToS3(\r\n  blob: Blob,\r\n  key: string\r\n): Promise<string> {\r\n  // This assumes AWS SDK v3 is configured\r\n  // Implementation depends on your S3 setup\r\n  console.log(`Uploading video to S3: ${key}`);\r\n  \r\n  // For now, return a placeholder\r\n  return `https://ganapathi-videos.s3.amazonaws.com/${key}`;\r\n}\r\n\r\n// ============================================================\r\n// Status Check\r\n// ============================================================\r\nexport function isVideoGenerationConfigured(): boolean {\r\n  return !!(HF_API_KEY || RUNWAY_API_KEY);\r\n}\r\n\r\nexport function getVideoProvider(): string {\r\n  if (RUNWAY_API_KEY) return \"runway\";\r\n  if (HF_API_KEY) return \"huggingface\";\r\n  return \"none\";\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\G R  HARSHA\\OneDrive\\Desktop\\Ganapathi Mentor AI\\neural-code-symbiosis\\lib\\youtube.ts","messages":[{"ruleId":"no-console","severity":1,"message":"Unexpected console statement.","line":19,"column":5,"nodeType":"MemberExpression","messageId":"unexpected","endLine":19,"endColumn":16,"suggestions":[{"fix":{"range":[590,717],"text":""},"messageId":"removeConsole","data":{"propertyName":"log"},"desc":"Remove the console.log()."}]},{"ruleId":"no-console","severity":1,"message":"Unexpected console statement.","line":21,"column":9,"nodeType":"MemberExpression","messageId":"unexpected","endLine":21,"endColumn":22,"suggestions":[{"fix":{"range":[756,820],"text":""},"messageId":"removeConsole","data":{"propertyName":"error"},"desc":"Remove the console.error()."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":53,"column":42,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":53,"endColumn":45,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1879,1882],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1879,1882],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"const YOUTUBE_API_KEY = process.env.YOUTUBE_API_KEY;\r\nconst YOUTUBE_BASE_URL = 'https://www.googleapis.com/youtube/v3';\r\n\r\nexport interface YouTubeVideo {\r\n    id: string;\r\n    title: string;\r\n    description: string;\r\n    thumbnail: string;\r\n    channelTitle: string;\r\n    publishedAt: string;\r\n    url: string;\r\n}\r\n\r\n/**\r\n * Search YouTube for relevant tutorial/educational videos.\r\n * Filters to recent videos (last 3 years) that are embeddable & publicly accessible.\r\n */\r\nexport async function searchYouTubeVideos(query: string, maxResults: number = 5): Promise<YouTubeVideo[]> {\r\n    console.log(`[YouTube] Searching for: ${query}, Key configured: ${!!YOUTUBE_API_KEY}, Key length: ${YOUTUBE_API_KEY?.length}`);\r\n    if (!YOUTUBE_API_KEY) {\r\n        console.error('[YouTube] API Key is missing in lib/youtube.ts');\r\n        throw new Error('YOUTUBE_API_KEY is not configured');\r\n    }\r\n\r\n    // Only return videos published in the last 3 years\r\n    const threeYearsAgo = new Date();\r\n    threeYearsAgo.setFullYear(threeYearsAgo.getFullYear() - 3);\r\n    const publishedAfter = threeYearsAgo.toISOString();\r\n\r\n    const params = new URLSearchParams({\r\n        part: 'snippet',\r\n        q: `${query} tutorial 2024`,\r\n        maxResults: maxResults.toString(),\r\n        type: 'video',\r\n        order: 'relevance',\r\n        relevanceLanguage: 'en',\r\n        safeSearch: 'strict',\r\n        videoDuration: 'medium',\r\n        videoEmbeddable: 'true',\r\n        publishedAfter,\r\n        key: YOUTUBE_API_KEY,\r\n    });\r\n\r\n    const response = await fetch(`${YOUTUBE_BASE_URL}/search?${params}`);\r\n\r\n    if (!response.ok) {\r\n        const errorData = await response.json().catch(() => ({}));\r\n        throw new Error(`YouTube API Error: ${errorData.error?.message || response.statusText}`);\r\n    }\r\n\r\n    const data = await response.json();\r\n\r\n    return (data.items || []).map((item: any) => ({\r\n        id: item.id.videoId,\r\n        title: item.snippet.title,\r\n        description: item.snippet.description,\r\n        thumbnail: item.snippet.thumbnails?.high?.url || item.snippet.thumbnails?.default?.url,\r\n        channelTitle: item.snippet.channelTitle,\r\n        publishedAt: item.snippet.publishedAt,\r\n        url: `https://www.youtube.com/watch?v=${item.id.videoId}`,\r\n    }));\r\n}\r\n\r\n/**\r\n * Get video details (for richer data)\r\n */\r\nexport async function getVideoDetails(videoId: string) {\r\n    if (!YOUTUBE_API_KEY) throw new Error('YOUTUBE_API_KEY is not configured');\r\n\r\n    const params = new URLSearchParams({\r\n        part: 'snippet,statistics,contentDetails',\r\n        id: videoId,\r\n        key: YOUTUBE_API_KEY,\r\n    });\r\n\r\n    const response = await fetch(`${YOUTUBE_BASE_URL}/videos?${params}`);\r\n\r\n    if (!response.ok) throw new Error('Failed to fetch video details');\r\n\r\n    const data = await response.json();\r\n    const video = data.items?.[0];\r\n    if (!video) return null;\r\n\r\n    return {\r\n        id: video.id,\r\n        title: video.snippet.title,\r\n        description: video.snippet.description,\r\n        thumbnail: video.snippet.thumbnails?.high?.url,\r\n        channelTitle: video.snippet.channelTitle,\r\n        viewCount: video.statistics?.viewCount,\r\n        likeCount: video.statistics?.likeCount,\r\n        duration: video.contentDetails?.duration,\r\n        url: `https://www.youtube.com/watch?v=${video.id}`,\r\n    };\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\G R  HARSHA\\OneDrive\\Desktop\\Ganapathi Mentor AI\\neural-code-symbiosis\\middleware.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\G R  HARSHA\\OneDrive\\Desktop\\Ganapathi Mentor AI\\neural-code-symbiosis\\models\\Alert.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\G R  HARSHA\\OneDrive\\Desktop\\Ganapathi Mentor AI\\neural-code-symbiosis\\models\\Anomaly.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\G R  HARSHA\\OneDrive\\Desktop\\Ganapathi Mentor AI\\neural-code-symbiosis\\models\\Challenge.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\G R  HARSHA\\OneDrive\\Desktop\\Ganapathi Mentor AI\\neural-code-symbiosis\\models\\CodeReview.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\G R  HARSHA\\OneDrive\\Desktop\\Ganapathi Mentor AI\\neural-code-symbiosis\\models\\Concept.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount