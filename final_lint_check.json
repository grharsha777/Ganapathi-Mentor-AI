atch (error) {\r\n        console.error(error)\r\n        return []\r\n    }\r\n}\r\n\r\nexport async function generateSpeech(text: string, voiceId: string = '21m00Tcm4TlvDq8ikWAM'): Promise<ArrayBuffer | null> {\r\n    if (!ELEVENLABS_API_KEY) return null\r\n\r\n    try {\r\n        const res = await fetch(`${BASE_URL}/text-to-speech/${voiceId}`, {\r\n            method: 'POST',\r\n            headers: {\r\n                'Content-Type': 'application/json',\r\n                'xi-api-key': ELEVENLABS_API_KEY\r\n            },\r\n            body: JSON.stringify({\r\n                text,\r\n                model_id: 'eleven_monolingual_v1',\r\n                voice_settings: {\r\n                    stability: 0.5,\r\n                    similarity_boost: 0.75\r\n                }\r\n            })\r\n        })\r\n\r\n        if (!res.ok) {\r\n            const err = await res.text()\r\n            console.error('ElevenLabs Error:', err)\r\n            throw new Error('Failed to generate speech')\r\n        }\r\n\r\n        return await res.arrayBuffer()\r\n    } catch (error) {\r\n        console.error(error)\r\n        return null\r\n    }\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\G R  HARSHA\\OneDrive\\Desktop\\Ganapathi Mentor AI\\neural-code-symbiosis\\lib\\integrations\\semantic-scholar.ts","messages":[{"ruleId":"no-console","severity":1,"message":"Unexpected console statement.","line":27,"column":13,"nodeType":"MemberExpression","messageId":"unexpected","endLine":27,"endColumn":25,"suggestions":[{"fix":{"range":[806,880],"text":""},"messageId":"removeConsole","data":{"propertyName":"warn"},"desc":"Remove the console.warn()."}]},{"ruleId":"no-console","severity":1,"message":"Unexpected console statement.","line":33,"column":13,"nodeType":"MemberExpression","messageId":"unexpected","endLine":33,"endColumn":26,"suggestions":[{"fix":{"range":[1002,1067],"text":""},"messageId":"removeConsole","data":{"propertyName":"error"},"desc":"Remove the 