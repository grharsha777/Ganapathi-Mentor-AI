to-br from-background via-background to-primary/5\">\n      <div className=\"w-full max-w-md\">\n        <div className=\"text-center mb-8\">\n          <Link href=\"/\" className=\"inline-flex items-center gap-2 mb-6\">\n            <img src=\"/logo.png\" alt=\"Logo\" className=\"w-10 h-10 object-contain\" />\n            <span className=\"font-bold text-xl tracking-tight\">Ganapathi Mentor AI</span>\n          </Link>\n        </div>\n\n        <Card className=\"border-border/50 shadow-xl shadow-primary/5 bg-card/95 backdrop-blur-sm\">\n          <CardHeader className=\"space-y-1 pb-4\">\n            <CardTitle className=\"text-2xl font-semibold\">Welcome back</CardTitle>\n            <CardDescription>Sign in to continue to your dashboard</CardDescription>\n          </CardHeader>\n          <CardContent className=\"space-y-6\">\n            <div className=\"grid gap-3\">\n              <Button\n                type=\"button\"\n                variant=\"outline\"\n                className=\"w-full h-11 font-medium\"\n                onClick={() => handleOAuth('google')}\n                disabled={isLoading}\n              >\n                <img src=\"https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg\" alt=\"Google\" className=\"mr-2 h-4 w-4\" />\n                Continue with Google\n              </Button>\n            </div>\n\n            <div className=\"relative\">\n              <div className=\"absolute inset-0 flex items-center\">\n                <span className=\"w-full border-t\" />\n              </div>\n              <div className=\"relative flex justify-center text-xs uppercase\">\n                <span className=\"bg-card px-2 text-muted-foreground\">Or continue with email</span>\n              </div>\n            </div>\n\n            <form onSubmit={handleLogin} className=\"space-y-4\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"email\">Email</Label>\n                <div className=\"relative\">\n                  <Mail className=\"absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground\" />\n                  <Input\n                    id=\"email\"\n                    type=\"email\"\n                    placeholder=\"you@example.com\"\n                    required\n                    value={email}\n                    onChange={(e) => setEmail(e.target.value)}\n                    className=\"pl-9 h-11\"\n                  />\n                </div>\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"password\">Password</Label>\n                <Input\n                  id=\"password\"\n                  type=\"password\"\n                  required\n                  value={password}\n                  onChange={(e) => setPassword(e.target.value)}\n                  className=\"h-11\"\n                />\n              </div>\n              {error && (\n                <p className=\"text-sm text-destructive bg-destructive/10 p-3 rounded-lg\">{error}</p>\n              )}\n              <Button type=\"submit\" className=\"w-full h-11 font-medium\" disabled={isLoading}>\n                {isLoading ? (\n                  <Loader2 className=\"h-4 w-4 animate-spin mr-2\" />\n                ) : null}\n                {isLoading ? 'Signing in...' : 'Sign in'}\n              </Button>\n            </form>\n\n            <p className=\"text-center text-sm text-muted-foreground\">\n              Don&apos;t have an account?{' '}\n              <Link href=\"/auth/sign-up\" className=\"font-medium text-primary hover:underline\">\n                Sign up\n              </Link>\n            </p>\n          </CardContent>\n        </Card>\n\n        <p className=\"mt-6 text-center text-xs text-muted-foreground\">\n          By signing in, you agree to our terms of service and privacy policy.\n        </p>\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\G R  HAR